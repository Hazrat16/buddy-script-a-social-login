# Copy to `apps/web/.env` — Next.js only (no database here)

AUTH_SECRET="same-value-as-in-apps-api-env"

# Local API (default)
NEXT_API_BASE_URL=http://127.0.0.1:3001

# Legacy (still supported if unset above)
# API_INTERNAL_URL=http://127.0.0.1:3001

# Production: point server-side proxy + /uploads rewrite at your deployed API (no trailing slash required).
# On Vercel: add for **Production** and enable **Building** (same value), then redeploy.
# NEXT_API_BASE_URL=https://buddy-script-a-social-platform-production.up.railway.app

# Do not put DATABASE_URL in this file — only `apps/api` talks to Postgres.
