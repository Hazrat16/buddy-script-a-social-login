# Copy to `apps/web/.env` — Next.js only (no database here)

AUTH_SECRET="same-value-as-in-apps-api-env"

# Local API (default)
API_INTERNAL_URL=http://127.0.0.1:3001

# Production: point server-side proxy + /uploads rewrite at your deployed API (no trailing slash required).
# On Vercel: add this variable for **Production** and enable **Building** (same value), then redeploy — otherwise
# the proxy can fall back to localhost at build time.
# API_INTERNAL_URL=https://buddy-script-a-social-platform-production.up.railway.app
