# Copy to `apps/web/.env` — Next.js only (no database here)

AUTH_SECRET="same-value-as-in-apps-api-env"

# Express API origin (recommended name — not your Vercel / Next site URL)
# BACKEND_API_URL=http://127.0.0.1:3001

# Same as BACKEND_API_URL (many people paste the Vercel app URL here by mistake — use Railway / Express only)
NEXT_API_BASE_URL=http://127.0.0.1:3001

# Legacy (still supported if BACKEND_API_URL and NEXT_API_BASE_URL are unset)
# API_INTERNAL_URL=http://127.0.0.1:3001

# Production: your **Railway / Express** host only (no trailing slash required).
# On Vercel: enable for **Production**, **Preview**, and **Building** — not the vercel.app frontend URL.
# BACKEND_API_URL=https://buddy-script-a-social-platform-production.up.railway.app

# Do not put DATABASE_URL in this file — only `apps/api` talks to Postgres.
