# Copy to `apps/api/.env`

# PostgreSQL via Docker Compose (see root docker-compose.yml): host port 5433 → container 5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/social_app?schema=public"

# --- Production (Neon) ---
# Set DATABASE_URL in your hosting dashboard (never commit real passwords).
# Use the pooled connection string from the Neon console (includes ?sslmode=require).
# Optional Neon parameter for SCRAM channel binding:
#   &channel_binding=require
# Example shape (replace USER, PASSWORD, HOST with your Neon values):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
#
# After pointing at Neon, apply the schema once from a trusted environment:
#   npm run db:push -w api
# (or use Prisma Migrate in production if you adopt migrations.)

AUTH_SECRET="replace-with-openssl-rand-base64-32-min-chars"
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
